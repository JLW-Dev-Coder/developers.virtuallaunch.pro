{
  "project": "virtuallaunch-developer",
  "frontend": {
    "root": "public/",
    "onboarding": "public/onboarding.html",
    "successPage": "public/success.html",
    "additionalFiles": [
      "public/find-developers.html",
      "public/available.html",
      "public/index.html",
      "public/support.html",
      "public/reviews.html",
      "public/operator.html",
      "public/js/developers.js",
      "public/js/partials-loader.js",
      "public/partials/header.html",
      "public/partials/footer.html"
    ],
    "stateStorage": "sessionStorage",
    "paymentViewSelector": "#payment-page",
    "planSelectionTrigger": "selectPlan(plan)"
  },
  "formUtilities": [
    {
      "path": "functions/forms/clientReference.js",
      "type": "client-form-utility",
      "route": "/forms/onboarding",
      "contract": "contracts/onboarding.json",
      "contractVersion": 2,
      "contractMethods": ["POST", "PATCH"],
      "addedFields": ["skill_javascript", "skill_python", "skill_react", "skill_nodejs", "skill_typescript", "skill_aws", "skill_docker", "skill_mongodb", "skill_postgresql", "skill_other_skills", "ideal_role", "contract_type", "timezone"],
      "description": "Client-side submission and status utilities for the onboarding form."
    }
  ],
  "backend": {
    "entry": "workers/src/index.js",
    "framework": "Cloudflare Workers + Cloudflare Pages Functions",
    "runtime": "workerd",
    "routes": [
      { "method": "POST",  "path": "/forms/onboarding",              "handler": "functions/forms/onboarding.js#onRequestPost",          "description": "Submit new onboarding record to R2" },
      { "method": "GET",   "path": "/forms/onboarding",              "handler": "functions/forms/onboarding.js#onRequestGet",           "description": "Fetch record for form pre-fill by ?ref=VLP-xxx" },
      { "method": "PATCH", "path": "/forms/onboarding",              "handler": "functions/forms/onboarding.js#onRequestPatch",         "description": "Update existing record (plan, archived, status, etc.)" },
      { "method": "GET",   "path": "/forms/support/status",          "handler": "workers/src/index.js#handleSupportStatus",            "description": "Support status lookup by ?clientRef=VLP-xxx" },
      { "method": "GET",   "path": "/forms/developers",              "handler": "functions/forms/developers.js",                       "description": "List published developer profiles" },
      { "method": "POST",  "path": "/forms/stripe/create-session",   "handler": "functions/forms/stripe/create-session.js#onRequestPost", "description": "Create Stripe Checkout Session; returns { ok, url }" },
      { "method": "POST",  "path": "/forms/stripe/webhook",          "handler": "functions/forms/stripe/webhook.js#onRequestPost",     "description": "Receive and verify Stripe webhook events; patch R2 record" },
      { "method": "GET",   "path": "/forms/stripe/session-status",   "handler": "functions/forms/stripe/session-status.js#onRequestGet", "description": "Poll payment confirmation status by ?session_id=cs_xxx" }
    ],
    "webhookHandler": "functions/forms/stripe/webhook.js",
    "webhookEventHandlers": [
      "checkout.session.completed",
      "customer.subscription.created",
      "customer.subscription.updated",
      "customer.subscription.deleted",
      "invoice.payment_succeeded",
      "invoice.payment_failed"
    ],
    "sessionStatusEndpoint": "/forms/stripe/session-status",
    "sessionStatusResponseShape": {
      "ok": true,
      "status": "processing | completed | error",
      "plan": "free | paid | null",
      "webhookConfirmed": "boolean",
      "webhookEvent": "string | null",
      "vlp_ref": "string | null"
    },
    "missingEndpoints": []
  },
  "stripe": {
    "sdkVersion": "20.4.1",
    "webhookEndpoint": "https://api.virtuallaunch.pro/v1/webhooks/stripe",
    "webhookSecret": "env:STRIPE_WEBHOOK_SECRET",
    "successRedirect": "https://developers.virtuallaunch.pro/success.html?session_id={CHECKOUT_SESSION_ID}",
    "webhookEvents": [
      "checkout.session.completed",
      "customer.subscription.created",
      "customer.subscription.updated",
      "customer.subscription.deleted",
      "invoice.payment_succeeded",
      "invoice.payment_failed"
    ],
    "freePriceId": "price_1TD7P79ROeyeXOqeuTnVu3oS",
    "paidPriceId": "price_1TEtJw9ROeyeXOqeG9pEHCEt",
    "productId": "prod_UBULSPgsL0yRZv",
    "checkoutMode": {
      "free": "payment",
      "paid": "subscription"
    },
    "implementationStatus": "IMPLEMENTED — create-session, webhook, and session-status Pages Functions live as of 2026-03-25"
  },
  "paymentStates": {
    "states": ["plan-selection", "processing", "completed", "error"],
    "storageKey": "vl_payment_state",
    "storageType": "sessionStorage",
    "completedTriggers": ["checkout.session.completed", "invoice.payment_succeeded"],
    "errorTriggers": ["invoice.payment_failed"],
    "pollingTimeoutSeconds": 30,
    "pollingIntervalSeconds": 2,
    "implementationStatus": "IMPLEMENTED — vl_payment_state tracked in onboarding.html and success.html; success.html polls session-status every 2s up to 30s timeout"
  },
  "plans": [
    {
      "id": "free",
      "label": "Free",
      "priceId": "price_1TD7P79ROeyeXOqeuTnVu3oS",
      "checkoutMode": "payment",
      "unitAmount": 0,
      "recurring": false,
      "paymentMethodCollection": "if_required",
      "usesStripeCheckout": true,
      "captureFields": ["email", "full_name"]
    },
    {
      "id": "paid",
      "label": "$2.99/mo",
      "priceId": "price_1TEtJw9ROeyeXOqeG9pEHCEt",
      "checkoutMode": "subscription",
      "unitAmount": 299,
      "recurring": true,
      "recurringInterval": "month",
      "paymentMethodCollection": "always",
      "usesStripeCheckout": true,
      "captureFields": []
    }
  ],
  "storage": {
    "r2Binding": "ONBOARDING_R2",
    "r2Bucket": "onboarding-records",
    "recordKeyPattern": "onboarding-records/{eventId}.json",
    "sessionStorageKeys": {
      "vlp_ref": "Reference number (eventId) — set by onboarding.html on form submit; read by success.html and create-session",
      "vlp_email": "User email — set by onboarding.html on form submit; read by create-session",
      "vlp_full_name": "User full name — set by onboarding.html on form submit; read by create-session",
      "vl_payment_state": "Current payment state: plan-selection | processing | completed | error"
    }
  },
  "env": [
    "ONBOARDING_R2",
    "GOOGLE_PRIVATE_KEY",
    "GOOGLE_CLIENT_EMAIL",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "STRIPE_PRICE_FREE",
    "STRIPE_PRICE_PAID",
    {
      "key": "STRIPE_INTERNAL_COUPON_ID",
      "purpose": "100% off coupon ID for internal paid plan testing",
      "required": false,
      "location": "Cloudflare dashboard"
    },
    {
      "key": "CF_ZONE_ID",
      "purpose": "Cloudflare zone ID for Analytics API — page view data in operator analytics",
      "required": false,
      "location": "wrangler.toml [vars]"
    },
    {
      "key": "CF_API_TOKEN",
      "purpose": "Cloudflare API token with Analytics:Read permission for operator analytics page view data",
      "required": false,
      "location": "Cloudflare dashboard (wrangler secret put CF_API_TOKEN)"
    }
  ],
  "sharedAssets": [
    {
      "path": "functions/_shared/email.js",
      "category": "asset",
      "governs": "Unified email dispatch — routes transactional to Gmail API, bulk to Resend"
    },
    {
      "path": "functions/_shared/emailTemplates.js",
      "category": "asset",
      "governs": "HTML and plain text templates for all outbound email flows"
    },
    {
      "path": "workers/cron-trigger/index.js",
      "category": "asset",
      "method": null,
      "endpoint": null,
      "title": "Cron Trigger Worker",
      "governs": "Standalone Worker that calls POST /cron/job-match on weekly schedule (Sunday 9am UTC)",
      "version": 1,
      "status": "active",
      "note": "Deployed separately as developers-virtuallaunch-pro-api on jamie-williams.workers.dev"
    }
  ],
  "dependencies": {
    "stripe": "20.4.1",
    "other": [
      "Cloudflare Workers / Pages Functions",
      "Cloudflare R2",
      "Google Gmail API (via functions/_shared/gmail.js)",
      "Tailwind CSS CDN 3.4.17",
      "Lucide icons CDN 0.263.0",
      "/_sdk/data_sdk.js (internal)",
      "/_sdk/element_sdk.js (internal)"
    ]
  },
  "auditLog": {
    "lastAuditDate": "2026-03-25",
    "filesRead": [
      ".claude/settings.local.json",
      ".claude/CLAUDE.md",
      ".claude/registry.json",
      "wrangler.toml",
      "workers/src/index.js",
      "functions/forms/onboarding.js",
      "functions/forms/stripe/create-session.js",
      "functions/forms/stripe/webhook.js",
      "functions/forms/stripe/session-status.js",
      "public/onboarding.html",
      "public/success.html",
      "public/js/developers.js",
      "public/available.html",
      "contracts/registry.json",
      "contracts/onboarding.json",
      "contracts/prod1_v1.json",
      "contracts/price1_v1.json",
      "contracts/price2_v1.json",
      "package.json"
    ],
    "nullsRemaining": [],
    "openQuestions": []
  }
}
