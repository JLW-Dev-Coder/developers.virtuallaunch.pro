{
  "auth": {
    "required": true,
    "type": "operator",
    "fields": ["email", "accessCode"],
    "sessionCookie": "vlp_operator_session"
  },
  "contract": {
    "title": "VLP Operator Dashboard Contract",
    "version": 2
  },
  "endpoints": {
    "auth":         { "path": "/operator/auth",         "method": "POST" },
    "submissions":  { "path": "/operator/submissions",  "method": "GET"  },
    "post":         { "path": "/operator/post",         "method": "POST" },
    "developers":   { "path": "/operator/developers",   "method": "GET"  },
    "analytics":    { "path": "/operator/analytics",    "method": "GET"  },
    "developerRef": { "path": "/operator/developer",    "method": "GET"  }
  },
  "postPayload": {
    "required": ["developerRef", "postContent"],
    "properties": {
      "developerRef":        { "type": "string" },
      "developerName":       { "type": "string" },
      "posterName":          { "type": "string" },
      "postContent":         { "type": "string" },
      "postUrl":             { "type": "string" },
      "dueDate":             { "type": "string" },
      "cronSchedule":        { "type": "string" },
      "status":              { "type": "string", "enum": ["complete","pending","upcoming"] },
      "nextNotificationDue": { "type": "string" }
    }
  },
  "storage": {
    "dashboardRecords": "dashboard-records/{developerRef}.json",
    "onboardingRecords": "onboarding-records/{eventId}.json"
  }
}
