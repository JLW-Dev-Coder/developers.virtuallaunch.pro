{
  "contracts": [
    {
      "authRequired": true,
      "category": "form",
      "dedupeKey": "payload.eventId",
      "endpoint": "https://api.yourdomain.com/forms/onboarding",
      "id": "form_onboarding",
      "method": "POST",
      "path": "app/contracts/forms/onboarding.contract.json",
      "receiptKeyPattern": "receipts/{source}/{eventId}.json",
      "receiptSource": "form",
      "signatureRequired": false,
      "status": "active",
      "usedOnPages": ["/public/onboarding.html"],
      "version": 1,
      "writes": ["onboarding-records"]
    }
  ],
  "registryVersion": 1,
  "stripeEndpoints": [
    {
      "id": "stripe_create_session",
      "category": "stripe",
      "method": "POST",
      "path": "functions/forms/stripe/create-session.js",
      "endpoint": "/forms/stripe/create-session",
      "status": "active",
      "authRequired": false,
      "signatureRequired": false,
      "writes": ["onboarding-records"],
      "version": 1
    },
    {
      "id": "stripe_webhook",
      "category": "stripe",
      "method": "POST",
      "path": "functions/forms/stripe/webhook.js",
      "endpoint": "/forms/stripe/webhook",
      "status": "active",
      "authRequired": false,
      "signatureRequired": true,
      "signatureHeader": "stripe-signature",
      "secretEnvVar": "STRIPE_WEBHOOK_SECRET",
      "writes": ["onboarding-records"],
      "handledEvents": [
        "checkout.session.completed",
        "customer.subscription.created",
        "customer.subscription.updated",
        "customer.subscription.deleted",
        "invoice.payment_succeeded",
        "invoice.payment_failed"
      ],
      "version": 1
    },
    {
      "id": "stripe_session_status",
      "category": "stripe",
      "method": "GET",
      "path": "functions/forms/stripe/session-status.js",
      "endpoint": "/forms/stripe/session-status",
      "status": "active",
      "authRequired": false,
      "signatureRequired": false,
      "reads": ["onboarding-records"],
      "version": 1
    }
  ],
  "sharedAssets": [
    {
      "id": "partial_header",
      "category": "partial",
      "path": "public/partials/header.html",
      "description": "Shared site header partial — injected into all pages by partials-loader.js",
      "usedOnPages": ["all"],
      "status": "active"
    },
    {
      "id": "partial_footer",
      "category": "partial",
      "path": "public/partials/footer.html",
      "description": "Shared site footer partial — injected into all pages by partials-loader.js; Product links populated dynamically",
      "usedOnPages": ["all"],
      "status": "active"
    },
    {
      "id": "js_partials_loader",
      "category": "script",
      "path": "public/js/partials-loader.js",
      "description": "Fetches and injects header.html and footer.html partials; populates footer Product links per page",
      "usedOnPages": ["all"],
      "status": "active"
    }
  ]
}