{
  "name": "support",
  "endpoints": {
    "status": {
      "route": "/forms/support/status",
      "method": "GET",
      "query": {
        "clientRef": {
          "type": "string",
          "required": true,
          "pattern": "^VLP-[a-zA-Z0-9]+$"
        }
      }
    },
    "posts": {
      "route": "/forms/support/posts",
      "method": "GET",
      "query": {
        "clientRef": {
          "type": "string",
          "required": true
        }
      }
    }
  },
  "response": {
    "status": { "ok": "boolean", "status": "string", "updatedAt": "string" },
    "posts":  { "ok": "boolean", "posts": "array (max 5)" }
  },
  "errors": ["invalid_reference", "not_found"]
}
